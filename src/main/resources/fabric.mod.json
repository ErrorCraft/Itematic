{
  "schemaVersion": 1,
  "id": "itematic",
  "version": "${version}",

  "name": "Itematic",
  "description": "A mod that adds data-driven items to Minecraft.",
  "authors": [
    "ErrorCraft"
  ],
  "contact": {
    "homepage": "https://github.com/ErrorCraft/Itematic",
    "sources": "https://github.com/ErrorCraft/Itematic"
  },

  "license": "CC0-1.0",
  "icon": "assets/itematic/icon.png",

  "environment": "*",
