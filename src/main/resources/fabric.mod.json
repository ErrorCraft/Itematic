{
  "schemaVersion": 1,
  "id": "itematic",
  "version": "${version}",

  "name": "Itematic",
  "description": "A mod that adds data-driven items to Minecraft.",
  "authors": [
    "ErrorCraft"
  ],
  "contact": {
    "homepage": "https://github.com/ErrorCraft/Itematic",
    "sources": "https://github.com/ErrorCraft/Itematic"
  },

  "license": "CC0-1.0",
  "icon": "assets/itematic/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "net.errorcraft.itematic.Itematic"
    ],
    "fabric-datagen": [
      "net.errorcraft.itematic.data.ItematicData"
    ]
  },
  "mixins": [
    "itematic.mixins.json",
    {
      "config": "itematic.client.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "itematic.accesswidener",
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/class_77": [
        "net/errorcraft/itematic/access/loot/entry/ItemEntryAccess"
      ],
      "net/minecraft/class_185": [
        "net/errorcraft/itematic/access/advancement/AdvancementDisplayAccess"
      ],
      "net/minecraft/class_507": [
        "net/errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_763": [
        "net/errorcraft/itematic/access/client/render/item/ItemModelsAccess"
      ],
      "net/minecraft/class_1297": [
        "net/errorcraft/itematic/access/entity/EntityAccess"
      ],
      "net/minecraft/class_1304": [
        "net/errorcraft/itematic/access/entity/EquipmentSlotAccess"
      ],
      "net/minecraft/class_1309": [
        "net/errorcraft/itematic/access/entity/LivingEntityAccess"
      ],
      "net/minecraft/class_1662": [
        "net/errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_1690": [
        "net/errorcraft/itematic/access/entity/vehicle/BoatEntityAccess"
      ],
      "net/minecraft/class_1730": [
        "net/errorcraft/itematic/access/PlayerAccess"
      ],
      "net/minecraft/class_1792": [
        "net/errorcraft/itematic/access/item/ItemAccess"
      ],
      "net/minecraft/class_1799": [
        "net/errorcraft/itematic/access/item/ItemStackAccess"
      ],
      "net/minecraft/class_1838": [
        "net/errorcraft/itematic/access/item/ItemUsageContextAccess"
      ],
      "net/minecraft/class_1856": [
        "net/errorcraft/itematic/access/recipe/IngredientAccess"
      ],
      "net/minecraft/class_1856\u0024class_1859": [
        "net/errorcraft/itematic/access/recipe/IngredientEntryAccess"
      ],
      "net/minecraft/class_1863": [
        "net/errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_1937": [
        "net/errorcraft/itematic/access/world/WorldAccess"
      ],
      "net/minecraft/class_2073": [
        "net/errorcraft/itematic/access/predicate/item/ItemPredicateAccess"
      ],
      "net/minecraft/class_2535": [
        "net/errorcraft/itematic/access/network/ClientConnectionAccess"
      ],
      "net/minecraft/class_2540": [
        "net/errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_2543": [
        "net/errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_2545": [
        "net/errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_2586": [
        "net/errorcraft/itematic/access/block/entity/BlockEntityAccess"
      ],
      "net/minecraft/class_2989": [
        "net/errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_3857": [
        "net/errorcraft/itematic/access/entity/projectile/thrown/ThrownItemEntityAccess"
      ],
      "net/minecraft/class_3959\u0024class_242": [
