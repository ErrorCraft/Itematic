{
  "schemaVersion": 1,
  "id": "itematic",
  "version": "${version}",

  "name": "Itematic",
  "description": "A mod that adds data-driven items to Minecraft.",
  "authors": [
    "ErrorCraft"
  ],
  "contact": {
    "homepage": "https://github.com/ErrorCraft/Itematic",
    "sources": "https://github.com/ErrorCraft/Itematic"
  },

  "license": "CC0-1.0",
  "icon": "assets/itematic/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "errorcraft.itematic.Itematic"
    ],
    "fabric-datagen": [
      "errorcraft.itematic.data.ItematicData"
    ]
  },
  "mixins": [
    "itematic.mixins.json"
  ],
  "accessWidener": "itematic.accesswidener",
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/class_77": [
        "errorcraft/itematic/access/loot/entry/ItemEntryAccess"
      ],
      "net/minecraft/class_185": [
        "errorcraft/itematic/access/advancement/AdvancementDisplayAccess"
      ],
      "net/minecraft/class_507": [
        "errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_763": [
        "errorcraft/itematic/access/client/render/item/ItemModelsAccess"
      ],
      "net/minecraft/class_1304": [
        "errorcraft/itematic/access/entity/EquipmentSlotAccess"
      ],
      "net/minecraft/class_1662": [
        "errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_1730": [
        "errorcraft/itematic/access/PlayerAccess"
      ],
      "net/minecraft/class_1792": [
        "errorcraft/itematic/access/item/ItemAccess"
      ],
      "net/minecraft/class_1799": [
        "errorcraft/itematic/access/item/ItemStackAccess"
      ],
      "net/minecraft/class_1856": [
        "errorcraft/itematic/access/recipe/IngredientAccess"
      ],
      "net/minecraft/class_1856\u0024class_1859": [
        "errorcraft/itematic/access/recipe/IngredientEntryAccess"
      ],
      "net/minecraft/class_1863": [
        "errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_2535": [
        "errorcraft/itematic/access/network/ClientConnectionAccess"
      ],
      "net/minecraft/class_2540": [
        "errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_2543": [
        "errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_2545": [
        "errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_2989": [
        "errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ],
      "net/minecraft/class_5257": [
        "errorcraft/itematic/access/registry/DynamicRegistryManagerAccess"
      ]
    }
  },

  "depends": {
    "fabricloader": ">=0.14.10",
    "fabric": "*",
    "minecraft": ">=1.19.3-alpha.22.42.a",
    "java": ">=17"
  },
  "suggests": {
  }
}
